# Copy this file to .env for local development. Never commit the resulting .env.
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=1
DATABASE_URL=postgres://user:password@127.0.0.1:5432/pharmapocket
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
WAGTAILADMIN_BASE_URL=http://127.0.0.1:8000
DJANGO_SITE_ID=1

# Frontend origin allowed to send session cookies to the API.
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Production defaults are secure automatically when DJANGO_DEBUG=0. Keep these
# explicit in the hosting provider when the frontend and API use different origins.
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SESSION_COOKIE_SAMESITE=None
DJANGO_CSRF_COOKIE_SAMESITE=None
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=1
